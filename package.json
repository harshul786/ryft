    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.2",
    "@types/react-dom": "^19.2.3",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.4.1",
    "cli-boxes": "^3.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "emoji-regex": "^10.6.0",
    "figures": "^6.1.0",
    "indent-string": "^5.0.0",
    "ink": "^6.8.0",
    "js-tiktoken": "^1.0.21",
