{
  "name": "ryft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ryft": "./bin/ryft.js"
  },
  "scripts": {
    "start": "tsx ./src/cli.ts",
    "proxy": "tsx ./src/runtime/proxyServer.ts",
    "test": "tsx --test ./test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc && echo '✓ Build complete in dist/'",
    "link": "npm run build && npm link",
    "unlink": "npm unlink"
