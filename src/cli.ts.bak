#!/usr/bin/env node
import chalk from "chalk";
import { Command } from "commander";
import readline from "node:readline/promises";
import { homedir } from "node:os";
import { stdin as input, stdout as output } from "node:process";
import type { ModelOption } from "./types.ts";
import { compactSession } from "./commands/compact.ts";
import { initBrowser } from "./browser/init_browser.ts";
import { formatBrowserTabs } from "./browser/common.ts";
import { recordMemoryTurn } from "./memory/store.ts";
import {
  defaultModelOption,
  formatModelPicker,
  resolveModelOption,
  initializeModelFromConfig,
  listModelOptions,
} from "./models/catalog.ts";
import {
  interactiveModelSelector,
  formatModelForPrompt,
} from "./models/model-selector.ts";
import { resolveModes } from "./modes/catalog.ts";
import { promptWithSession } from "./runtime/promptBuilder.ts";
import { createSession } from "./runtime/session.ts";
import { openProxyServer } from "./runtime/proxyServer.ts";
import { streamChatCompletion } from "./runtime/openaiClient.ts";
import { renderBanner, renderStatusLine } from "./ui/chalkDraw.ts";
import { AVAILABLE_COMMANDS } from "./ui/commandSuggestions.ts";
import prompts from "prompts";
import { loadConfig, applyCliOverrides } from "./config/config-loader.ts";
import { saveConfig } from "./config/config-writer.ts";
import {
  displayConfigView,
  configSet,
  configUnset,
} from "./config/commands.ts";
import { runOnboarding } from "./onboarding/onboardingFlow.ts";

const program = new Command();

program
  .name("ryft")
  .description("Lean OpenAI-native ai-code CLI")
  .option("--mode <modes...>", "select one or more modes")
  .option("--memory <mode>", "select a memory mode")
  .option(
    "--model <name>",
    "select a model id, label, or provider-qualified name",
  )
  .option("--proxy <url>", "use a local OpenAI-compatible proxy URL")
  .option(
    "--base-url <url>",
    "override the upstream OpenAI-compatible base URL",
  )
  .option("--api-key <key>", "override the upstream API key")
  .option("--browser", "initialize browser automation support")
  .option("--serve-proxy", "run only the local proxy server")
  .option("--prompt <text>", "send a single prompt and exit");

program.parse();

async function main(): Promise<void> {
  const opts = program.opts<{
    mode?: string[];
    memory?: "claude-like" | "hierarchy" | "session";
    model?: string;
    proxy?: string;
    baseUrl?: string;
    apiKey?: string;
    browser?: boolean;
    serveProxy?: boolean;
    prompt?: string;
  }>();

  if (opts.serveProxy) {
    const server = await openProxyServer();
    console.log(chalk.green(`Ryft proxy listening on ${server.url}`));
    process.stdin.resume();
    return;
  }

  // Create readline interface with tab-completion for / commands
  const SLASH_COMMANDS = AVAILABLE_COMMANDS.map((c) => c.command);
  const rl = readline.createInterface({
    input,
    output,
    completer: (line: string): [string[], string] => {
      if (line.startsWith("/")) {
        const hits = SLASH_COMMANDS.filter((c) => c.startsWith(line));
        return [hits.length ? hits : SLASH_COMMANDS, line];
      }
      return [[], line];
    },
  });

  // Run onboarding if this is first time setup
  const onboardingConfig = await runOnboarding();
  if (onboardingConfig && (onboardingConfig.apiKey || onboardingConfig.model)) {
    // Save onboarding results to config file
    await saveConfig(onboardingConfig, { target: "global", backup: true });
  }

  // Load config with precedence: defaults < global config < workspace config < CLI flags
  let config = loadConfig();
  config = applyCliOverrides(config, opts);

  // Resolve modes from config or CLI
  const modes = opts.mode ?? config.defaultModes ?? ["coder"];

  // Resolve model from config or CLI with config-aware initialization
  const modelStr = opts.model ?? config.model;
  const model = initializeModelFromConfig(modelStr);

  // Resolve memory mode from config or CLI
  const memoryMode = opts.memory ?? config.defaultMemoryMode ?? "claude-like";

  const session = createSession({
    modes: resolveModes(modes),
    memoryMode: memoryMode as "claude-like" | "hierarchy" | "session",
    model,
    cwd: process.cwd(),
    homeDir: homedir(),
    proxyUrl:
      opts.proxy ?? config.proxyUrl ?? process.env.RYFT_PROXY_URL ?? null,
    baseUrl:
      opts.baseUrl ??
      config.baseUrl ??
      process.env.OPENAI_BASE_URL ??
      "https://api.openai.com/v1",
    apiKey: opts.apiKey ?? config.apiKey ?? process.env.OPENAI_API_KEY ?? "",
  });

  if (opts.browser) {
    await initBrowser(session);
  }

  if (opts.prompt) {
    const prompt = await promptWithSession(session, opts.prompt);
    const response = await streamChatCompletion({
      baseUrl: session.config.baseUrl,
      apiKey: session.config.apiKey,
      model: session.config.model.id,
      messages: prompt,
      signal: session.abortController.signal,
      onDelta: (chunk) => process.stdout.write(chunk),
    });
    if (response.text) {
      session.appendAssistant(response.text);
      session.setMemoryState(
        await recordMemoryTurn(
          session.memoryMode.name,
          {
            cwd: session.config.cwd,
            homeDir: session.config.homeDir,
            sessionSnapshot: session.memoryState.snapshot,
          },
          opts.prompt,
          response.text,
        ),
      );
    }
    if (response.usage) {
      process.stdout.write(`\n${renderStatusLine(session, response.usage)}`);
    }
    process.stdout.write("\n");
    return;
  }

  console.log(renderBanner(session));

  // Helper function to get prompt with current model
  const getPrompt = (): string => {
    const modelPart = formatModelForPrompt(session.config.model);
    return chalk.cyan(`ryft ${modelPart}> `);
  };

  while (true) {
    const line = await rl.question(getPrompt());
    const trimmed = line.trim();
    if (!trimmed) continue;

    if (trimmed === "/exit" || trimmed === "/quit") break;

    // Bare "/" — show command suggestions
    if (trimmed === "/") {
      console.log("");
      const maxCmd = Math.max(
        ...AVAILABLE_COMMANDS.map((c) => c.command.length),
      );
      for (const cmd of AVAILABLE_COMMANDS) {
        console.log(
          `  ${chalk.cyan(cmd.command.padEnd(maxCmd + 2))}${chalk.dim(cmd.description)}`,
        );
      }
      console.log("");
      continue;
    }

    if (trimmed === "/mode" || trimmed.startsWith("/mode ")) {
      session.setModes(resolveModes(trimmed.split(/\s+/).slice(1)));
      console.log(renderStatusLine(session));
      continue;
    }

    if (trimmed.startsWith("/memory")) {
      session.setMemoryMode(
        (trimmed.split(/\s+/)[1] ?? "claude-like") as
          | "claude-like"
          | "hierarchy"
          | "session",
      );
      console.log(renderStatusLine(session));
      continue;
    }

    if (trimmed === "/model" || trimmed.startsWith("/model ")) {
      const raw = trimmed.split(/\s+/).slice(1).join(" ").trim();

      if (!raw) {
        // Interactive model picker using arrow-key selection
        const allModels = listModelOptions();
        const choices = allModels.map((m) => ({
          title: `${m.label}  ${chalk.dim(`(${m.id})`)}`,
          description: m.description,
          value: m,
        }));
        const currentIndex = allModels.findIndex(
          (m) => m.id === session.config.model.id,
        );

        console.log("");
        const response = await prompts(
          {
            type: "select",
            name: "model",
            message: "Select a model",
            choices,
            initial: currentIndex >= 0 ? currentIndex : 0,
            hint: "arrow keys to navigate, Enter to confirm",
          },
          { onCancel: () => null },
        );
        console.log("");

        if (response.model) {
          const selected: ModelOption = response.model;
          session.setModel(selected);
          console.log(chalk.green(`✓ Model set to ${selected.label}`));

          const saveResponse = await prompts(
            {
              type: "confirm",
              name: "save",
              message: "Save to config?",
              initial: true,
            },
            { onCancel: () => null },
          );
          if (saveResponse.save) {
            try {
              saveConfig(
                { model: selected.id },
                { target: "global", backup: false },
              );
              console.log(chalk.green("✓ Saved to global config"));
            } catch (err) {
              console.log(chalk.yellow(`Warning: Could not save: ${err}`));
            }
          }
          console.log("");
        }
      } else {
        // Non-interactive: just resolve the model
        const selected = resolveModelOption(raw);
        if (selected) {
          session.setModel(selected);
          console.log(chalk.green(`✓ Model set to ${selected.label}`));
        } else {
          console.log(chalk.yellow(`Unknown model: ${raw}`));
        }
      }
      continue;
    }

    if (trimmed === "/compact") {
      await compactSession(session);
      console.log(chalk.yellow("Conversation compacted."));
      continue;
    }

    if (trimmed === "/skills") {
      console.log(await session.describeSkills());
      continue;
    }

    if (trimmed === "/mcp") {
      console.log(session.describeMcp());
      continue;
    }

    if (trimmed === "/help") {
      console.log(chalk.bold("\nAvailable Commands:\n"));
      console.log("  /model              - select or display current model");
      console.log(
        "  /mode <modes...>    - select modes (coder, browser-surff, debugger, shared)",
      );
      console.log(
        "  /memory <mode>      - select memory mode (claude-like, hierarchy, session)",
      );
      console.log("  /skills             - list available AI skills");
      console.log("  /mcp                - list MCP server connections");
      console.log("  /compact            - compact conversation history");
      console.log("  /browser            - initialize browser automation");
      console.log("  /config             - display current configuration");
      console.log("  /config view        - display configuration");
      console.log("  /config set <k> <v> - set a config value");
      console.log("  /config unset <k>   - reset a config field to default");
      console.log("  /help               - show this help message");
      console.log("  /exit, /quit        - exit the REPL\n");
      continue;
    }

    if (trimmed === "/config") {
      displayConfigView();
      continue;
    }

    if (trimmed.startsWith("/config view")) {
      displayConfigView();
      continue;
    }

    if (trimmed.startsWith("/config set ")) {
      const parts = trimmed.slice(12).trim().split(/\s+/);
      if (parts.length < 2) {
        console.log(chalk.yellow("Usage: /config set <field> <value>"));
        continue;
      }
      const [field, ...valueParts] = parts;
      const value = valueParts.join(" ");
      try {
        await configSet(field, value, "global");
      } catch (error) {
        console.log(chalk.red((error as Error).message));
      }
      continue;
    }

    if (trimmed.startsWith("/config unset ")) {
      const field = trimmed.slice(14).trim();
      if (!field) {
        console.log(chalk.yellow("Usage: /config unset <field>"));
        continue;
      }
      try {
        configUnset(field, "global");
      } catch (error) {
        console.log(chalk.red((error as Error).message));
      }
      continue;
    }

    if (trimmed === "/config help") {
      console.log(chalk.bold("Config Commands:"));
      console.log("  /config                - display current config");
      console.log("  /config view           - display current config");
      console.log("  /config set <key> <value> - set a config value");
      console.log("  /config unset <key>    - reset a config field to default");
      console.log(
        "\\nAvailable fields: model, provider, defaultModes, defaultMemoryMode,",
      );
      console.log(
        "  defaultBrowser, proxyUrl, baseUrl, apiKey, logLevel, showTokens",
      );
      continue;
    }

    if (trimmed === "/browser") {
      await initBrowser(session);
      continue;
    }

    if (trimmed.startsWith("/browser ")) {
      if (!session.browser) {
        await initBrowser(session);
      }
      const browser = session.browser;
      if (!browser) {
        console.log(chalk.red("Browser controller is unavailable."));
        continue;
      }

      const [, subcommand, ...rest] = trimmed.split(/\s+/);
      if (subcommand === "open") {
        const url = rest.join(" ").trim();
        if (!url) {
          console.log(chalk.yellow("Usage: /browser open <url>"));
          continue;
        }
        const tab = await browser.openUrl(url);
        console.log(tab ? `Opened ${tab.url}` : `Opened ${url}`);
        continue;
      }

      if (subcommand === "tabs") {
        const tabs = await browser.listTabs();
        console.log(formatBrowserTabs(tabs));
        continue;
      }

      if (subcommand === "devtools") {
        const tabId = rest[0];
        await browser.openDevTools(tabId);
        console.log(chalk.green("DevTools opened."));
        continue;
      }

      if (subcommand === "close") {
        await browser.close();
        session.setBrowser(null);
        console.log(chalk.green("Browser controller closed."));
        continue;
      }

      console.log(
        chalk.yellow(
          "Usage: /browser [open <url> | tabs | devtools [tab-id] | close]",
        ),
      );
      continue;
    }

    // Catch-all for unrecognized / commands
    if (trimmed.startsWith("/")) {
      const command = trimmed.split(/\s+/)[0];
      console.log(chalk.yellow(`Unknown command: ${command}`));
      console.log(
        chalk.dim(
          "Available commands: /mode, /model, /memory, /config, /skills, /mcp, /browser, /compact, /help, /exit",
        ),
      );
      continue;
    }

    const prompt = await promptWithSession(session, trimmed);
    process.stdout.write(chalk.dim("thinking...\n"));
    try {
      session.appendUser(trimmed);
      const response = await streamChatCompletion({
        baseUrl: session.config.baseUrl,
        apiKey: session.config.apiKey,
        model: session.config.model.id,
        messages: prompt,
        signal: session.abortController.signal,
        onDelta: (chunk) => process.stdout.write(chunk),
      });
      if (response.text) {
        session.appendAssistant(response.text);
        session.setMemoryState(
          await recordMemoryTurn(
            session.memoryMode.name,
            {
              cwd: session.config.cwd,
              homeDir: session.config.homeDir,
              sessionSnapshot: session.memoryState.snapshot,
            },
            trimmed,
            response.text,
          ),
        );
      }
      process.stdout.write("\n");
    } catch (error) {
      console.error(
        chalk.red(error instanceof Error ? error.message : String(error)),
      );
    }
  }

  rl.close();
}

await main();
